{
  "name": "sendbird-ai-agent-cdn-sample",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.1",
    "@types/node": "^20.10.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "quoteProps": "preserve",
    "trailingComma": "all",
    "bracketSpacing": true,
    "arrowParens": "always",
    "plugins": [
      "@trivago/prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "<THIRD_PARTY_MODULES>",
      "@sendbird[./]?",
      "@(components|constants|types|utils)[./]?",
      "^[./]"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true,
    "importOrderCaseInsensitive": false
  }
}
